{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build && tsc --build --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "clean": "rm -rf packages/*/dist",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json}\" \"packages/*/tests/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,json}\" \"packages/*/tests/**/*.{ts,tsx,json}\""
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "fast-check": "^4.6.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "~8.0.0",
    "vitest": "~4.1.0"
  }
}
